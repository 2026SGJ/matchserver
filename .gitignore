# 依赖目录
node_modules/

# 日志文件
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# 构建输出
dist/
build/
out/
*.tsbuildinfo

# 环境变量文件
.env
.env.local
.env.*.local

# 运行时数据
*.pid
*.seed
*.pid.lock
data/

# 测试覆盖率
coverage/
.nyc_output/

# 缓存目录
.cache/
.eslintcache
.parcel-cache/

# IDE / 编辑器配置（保留个人习惯，但建议忽略）
.vscode/
.idea/
*.swp
*.swo
*~

# 操作系统生成文件
Thumbs.db
.DS_Store

# 打包文件
*.tgz
*.tar.gz
*.zip

# 临时文件
tmp/
temp/

# 私有密钥 / 证书
*.pem
*.key
*.crt
*.p12

# 数据库文件
*.sqlite
*.db

# 特定框架（如 Next.js）
.next/
out/

# 特定工具（如 pnpm）
.pnpm-debug.log